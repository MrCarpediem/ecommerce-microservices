# Common environment values for local development
# Replace any placeholder values before deploying.

FRONTEND_URL=http://localhost:5173
REGISTRY_URL=http://localhost:5000
JWT_SECRET=replace_with_secure_secret
SERVICE_SECRET=replace_with_service_secret
JWT_EXPIRES_IN=24h

# Example service endpoints for local Docker Compose
# SERVICE_URL values should be set per service using the service name within Docker Compose.
# SERVICE_URL=http://auth:5001
# SERVICE_URL=http://user:5002
# SERVICE_URL=http://product:5003
# SERVICE_URL=http://cart:5004
# SERVICE_URL=http://order:5005

# Example MongoDB connection string for local development
# MONGO_URI=mongodb://localhost:27017/<service-name>
